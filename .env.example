# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=https://vendingconnector.com

# Apify
APIFY_API_TOKEN=your-apify-api-token
APIFY_ACTOR_ID=your-username~lead-generator-worker

# Stripe (subscription paywall — $19.99/mo)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Cron security
CRON_SECRET=your-random-secret-string

# Resend (transactional email — receipt + lead details after Stripe checkout)
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourverifieddomain.com

# PandaDoc (e-signature workflows)
PANDADOC_API_KEY=your-pandadoc-api-key
PANDADOC_WEBHOOK_SECRET=your-pandadoc-webhook-secret

# PayPal (payment collection for pipeline steps)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_MODE=sandbox
